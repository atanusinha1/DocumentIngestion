{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "SharePoint": { 
    "SiteUrl": "https://yoursharepointsite.sharepoint.com/sites/yoursite",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret"
  },
  "Redis": { 
    "ConnectionString": "localhost:6379"
  },
  "SqlConnector": {
    "ConnectionString": "Server=tcp:myserver.database.windows.net;Database=mydb;...",
    "PollIntervalMinutes": 15,
    "Tables": [
      {
        "TableName":       "KnowledgeBase",
        "IdColumn":        "ArticleId",
        "TitleColumn":     "ArticleName",
        "ContentColumn":   "ArticleBody",
        "ModifiedColumn":  "UpdatedAt",
        "AuthorColumn":    "AuthorName",
        "MetadataColumns": ["Category", "Status"]
      }
    ]
  },
  "ServiceBus": {
    "ConnectionString": "Endpoint=sb://yourns.servicebus.windows.net/;...",
    "TopicMappings": {
      "document-ingested": "document-ingested",
      "chunks-ready":      "chunks-ready",
      "embeddings-ready":  "embeddings-ready"
    }
  }
}
